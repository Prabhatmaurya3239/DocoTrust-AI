# =============================================================================
# DocuTrust — environment configuration
# Copy this file to `.env` and fill in the values. NEVER commit your real .env.
# =============================================================================

# --------------------------------------------------------------------- Django
# Generate a new key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
DJANGO_CSRF_TRUSTED_ORIGINS=https://*.vusercontent.net,https://*.vercel.app
DJANGO_TIME_ZONE=UTC
DJANGO_LOG_LEVEL=INFO
DOCUTRUST_LOG_LEVEL=DEBUG

# ------------------------------------------------------------------------ CORS
DJANGO_CORS_ALLOW_ALL=True
DJANGO_CORS_ALLOWED_ORIGINS=

# -------------------------------------------------------------------- Security
# Only used when DJANGO_DEBUG=False
DJANGO_SECURE_SSL_REDIRECT=True

# ----------------------------------------------------------------------- OpenAI
# Required for embeddings and answer generation (added in later modules).
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ------------------------------------------------------------------- Embeddings
# Local sentence-transformers model used as a fallback / offline embedder.
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# -------------------------------------------------------------------- ChromaDB
CHROMA_PERSIST_DIR=chroma_store

# -------------------------------------------------------------- RAG parameters
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=5
RAG_RELEVANCE_THRESHOLD=0.6
RAG_MAX_REWRITES=2

# ------------------------------------------------------------------- Uploads
MAX_UPLOAD_SIZE_MB=25
ALLOWED_UPLOAD_EXTENSIONS=pdf,docx,txt
